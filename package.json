{
  "name": "finance-data-api",
  "version": "0.1.0",
  "description": "Deterministic finance data API for a finance agent MVP.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "validate": "npm run typecheck && npm test",
    "db:create": "tsx scripts/create-db.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "news": "tsx scripts/news.ts",
    "news:collect": "tsx scripts/news.ts collect"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "openapi-types": "^12.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
